{
	":":
		{
			"prefix":":",
			"scope":"javascript",
			"body":
				[
					"${1:левая_часть}:${2:правая_часть}"
				]
		},
	"?:":
		{
			"prefix":"?:",
			"scope":"javascript",
			"body":
				[
					"${1:условие}?${2:значение_если_истина}:${3:значение_если_ложь}"
				]
		},
	"=":
		{
			"prefix":"=",
			"body":
				[
					"${1:левая_часть}=${2:правая_часть};"
				]
		},
	"=>":
		{
			"prefix":"=>",
			"body":
				[
					"(${1:парам})=>${2:выражение}"
				]
		},
	"continue":
		{
			"prefix":"continue",
			"body":
				[
					"continue;"
				]
		},
	"for":
		{
			"prefix":"for",
			"body":
				[
					"for(const ${2:элемент} of ${1:итерируемое})",
					"{",
					"\t${3:код}",
					"}"
				]
		},
	"function":
		{
			"prefix":"function",
			"body":
				[
					"function(${1:парам})",
					"{",
					"\t${2:код}",
					"}"
				]
		},
	"if":
		{
			"prefix":"if",
			"body":
				[
					"if(${1:условие})",
					"{",
					"\t${2:код}",
					"}"
				]
		},
	"method":
		{
			"prefix":"method",
			"body":
				[
					"${1:имя}()",
					"{",
					"\t${2:код}",
					"}"
				]
		},
	"label":
		{
			"prefix":"label",
			"body":
				[
					"//~~~~"
				]
		},
	"new":
		{
			"prefix":"new",
			"body":
				[
					"new ${1:Имя}()"
				]
		},
	"return":
		{
			"prefix":"return",
			"body":
				[
					"return ${1:выражение};"
				]
		}
}
